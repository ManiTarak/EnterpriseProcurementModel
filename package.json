{
  "name": "EnterpriseProcurementModel",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "[production]": {
          "startagy": "JWT"
      },
        "[development]": {
          "stratagy": "mocked",
          "users": {
            "mani": {
              "roles": [
                "Display"
              ],
              "userAttributes": {
                "BankName": [
                  "Bank of America"
                ],
                "Country": [
                  "IND"
                ]
              }
            },
            "Tarak": {
              "roles": [
                "Edit"
              ],
              "userAttributes": {
                "BankName": [
                  "Bank of America"
                ],
                "Country": [
                  "IND"
                ]
              }
            }
          }
        },
        "kind": "mocked"
      }
      
    }
  }
}
