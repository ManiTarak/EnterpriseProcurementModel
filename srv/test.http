### get items from purchase order
http://localhost:4004/odata/v4/EPMService/ProductViewSet

### Get pos and poitems from pos

http://localhost:4004/odata/v4/EPMService/POEntitySet?$expand=Items

### POST Data to PoItems

POST http://localhost:4004/odata/v4/EPMService/POEntitySet
Content-Type: application/json

    {
      "CURRENCY_code": "USD",
      "GROSS_Amount": 2000,
      "NET_Amount": 1431,
      "TAX_Amount": 987,
      "NODE_KEY": "PO006",
      "PO_ID": "PO-2026-0006",
      "PARTNER_GUID_NODE_KEY": "BP103",
      "LIFECYCLE_STATUS": "A",
      "OVERALL_STATUS": "O"
    }

### Patch updating the amount of PO001 amount
PATCH http://localhost:4004/odata/v4/EPMService/POEntitySet/PO001
Content-Type: application/json

{
   "GROSS_Amount": 1930
}

### delete Purchase Order
DELETE http://localhost:4004/odata/v4/EPMService/POEntitySet/PO001

### post update po and pois together
POST http://localhost:4004/odata/v4/EPMService/POEntitySet
Content-Type: application/json

{
      "CURRENCY_code": "INR",
      "GROSS_Amount": 1850,
      "NET_Amount": 720,
      "TAX_Amount": 130,
      "NODE_KEY": "PO007",
      "PO_ID": "PO-2026-0007",
      "PARTNER_GUID_NODE_KEY": "BP101",
      "LIFECYCLE_STATUS": "N",
      "OVERALL_STATUS": "O",
      "Items": [
        {
          "CURRENCY_code": "INR",
          "GROSS_Amount": 1850,
          "NET_Amount": 720,
          "TAX_Amount": 130,
          "NODE_KEY": "ITEM009",
          "PARENT_KEY_NODE_KEY": "PO007",
          "PO_ITEM_POS": 10,
          "PRODUCT_GUID_NODE_KEY": "PRD103"
        }
      ]
    }

