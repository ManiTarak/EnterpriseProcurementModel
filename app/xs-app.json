{
    "welcomeFile": "webapp/",
    "authenticationMethod": "route",
    "sessionTimeout": 100,
    "routes": [
        {
            "source": "^/webapp/(.*)",
            "target": "/$1",
            "localDir": "webapp/",
            "authenticationType": "xsuaa"
        },
        {
            "source": "^/(.*)$",
            "authenticationType": "xsuaa",
            "destination": "srv-api"
        }
    ]
}
